rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             (!('riskProfile' in data) || data.riskProfile in ['conservative', 'moderate', 'aggressive']) &&
             (!('balance' in data) || data.balance is number) &&
             data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'riskProfile', 'goals', 'balance']);
    }

    // Portfolio Validation
    function isValidPortfolioItem(data) {
      return data.keys().hasAll(['userId', 'assetName', 'quantity']) &&
             data.userId == request.auth.uid &&
             data.assetName is string && data.assetName.size() <= 100 &&
             data.quantity is number && data.quantity >= 0;
    }

    match /users/{userId}/portfolio/{itemId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidPortfolioItem(incoming());
      allow update: if isOwner(userId) && isValidPortfolioItem(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['quantity', 'avgPrice']);
      allow delete: if isOwner(userId);
    }

    // Learning Progress Validation
    function isValidLearningProgress(data) {
      return data.keys().hasAll(['userId']) &&
             data.userId == request.auth.uid;
    }

    match /users/{userId}/learning/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidLearningProgress(incoming());
    }
  }
}
